{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "paths": {
      "@levelzero/core/*": ["./packages/core/src/*"],
      "@levelzero/*": ["./packages/*/src/index.ts"]
    }
  }
}
