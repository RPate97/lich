{
  "name": "{{projectName}}",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "lich up",
    "build": "bun run --filter '*' build",
    "test": "bun run --filter '*' test",
    "lint": "bun run --filter '*' lint",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@lich/plugin-better-auth": "^0.1.0",
    "@lich/plugin-hono": "^0.1.0",
    "@lich/plugin-next": "^0.1.0",
    "@lich/plugin-playwright": "^0.1.0",
    "@lich/plugin-postgres": "^0.1.0",
    "@lich/plugin-prisma": "^0.1.0",
    "@lich/plugin-shadcn": "^0.1.0",
    "@lich/plugin-typed-client": "^0.1.0",
    "@lich/plugin-vitest": "^0.1.0",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@lich/core": "^0.1.0",
    "prisma": "^7.0.0",
    "typescript": "^5.4.0"
  }
}
