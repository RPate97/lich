{
  "name": "@lich/lich",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "bin": {
    "lich": "./dist/lich"
  },
  "scripts": {
    "build": "bun build --compile --target=bun --outfile=dist/lich src/bin/lich.ts",
    "build:daemon": "bun build --compile --target=bun --outfile=dist/lich-daemon src/bin/lich-daemon.ts",
    "dev": "bun run src/bin/lich.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/bun": "^1.1.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "dependencies": {
    "ajv": "^8.20.0",
    "chokidar": "^5.0.0",
    "mri": "^1.2.0",
    "yaml": "^2.9.0"
  }
}
