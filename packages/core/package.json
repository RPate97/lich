{
  "name": "@lich/core",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./errors": {
      "types": "./dist/errors.d.ts",
      "import": "./dist/errors.js",
      "require": "./dist/errors.cjs"
    },
    "./registry": {
      "types": "./dist/registry.d.ts",
      "import": "./dist/registry.js",
      "require": "./dist/registry.cjs"
    },
    "./worktree": {
      "types": "./dist/worktree.d.ts",
      "import": "./dist/worktree.js",
      "require": "./dist/worktree.cjs"
    },
    "./services/context": {
      "types": "./dist/services/context.d.ts",
      "import": "./dist/services/context.js",
      "require": "./dist/services/context.cjs"
    },
    "./services/types": {
      "types": "./dist/services/types.d.ts",
      "import": "./dist/services/types.js",
      "require": "./dist/services/types.cjs"
    },
    "./commands/up": {
      "types": "./dist/commands/up.d.ts",
      "import": "./dist/commands/up.js",
      "require": "./dist/commands/up.cjs"
    },
    "./compose/naming": {
      "types": "./dist/compose/naming.d.ts",
      "import": "./dist/compose/naming.js",
      "require": "./dist/compose/naming.cjs"
    },
    "./adapters/registry": {
      "types": "./dist/adapters/registry.d.ts",
      "import": "./dist/adapters/registry.js",
      "require": "./dist/adapters/registry.cjs"
    },
    "./adapters/portless/types": {
      "types": "./dist/adapters/portless/types.d.ts",
      "import": "./dist/adapters/portless/types.js",
      "require": "./dist/adapters/portless/types.cjs"
    },
    "./env/registry": {
      "types": "./dist/env/registry.d.ts",
      "import": "./dist/env/registry.js",
      "require": "./dist/env/registry.cjs"
    }
  },
  "bin": {
    "lich": "./dist/bin.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "@types/pg": "^8.11.0",
    "@types/pngjs": "^6.0.5",
    "@vitest/coverage-v8": "^1.6.0",
    "bun-types": "^1.2.0",
    "hono": "^4.12.19",
    "playwright": "^1.45.0",
    "pngjs": "^7.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "dependencies": {
    "@lich/dashboard": "workspace:*",
    "@prisma/client": "^5.18.0",
    "concurrently": "^9.0.0",
    "pg": "^8.12.0",
    "prisma": "^5.18.0",
    "ts-morph": "^28.0.0",
    "yaml": "^2.9.0"
  }
}
